{
  "name": "joplin-plugin-quick-links-plus",
  "version": "0.6.0",
  "scripts": {
    "dist": "webpack --env joplin-plugin-config=buildMain && webpack --env joplin-plugin-config=buildExtraScripts && webpack --env joplin-plugin-config=createArchive",
    "prepare": "npm run dist",
    "updateVersion": "webpack --env joplin-plugin-config=updateVersion",
    "update": "npm install -g generator-joplin && yo joplin --node-package-manager npm --update --force"
  },
  "license": "MIT",
  "keywords": [
    "joplin-plugin"
  ],
  "files": [
    "publish"
  ],
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@codemirror/autocomplete": "^6.20.3",
    "chalk": "^4.1.0",
    "copy-webpack-plugin": "^13.0.1",
    "fs-extra": "^11.3.6",
    "glob": "^8.0.3",
    "tar": "^7.5.19",
    "ts-loader": "^9.6.2",
    "typescript": "^5.9.3",
    "webpack": "^5.108.3",
    "webpack-cli": "^4.10.0"
  },
  "description": "Quick Links Plus for Joplin",
  "author": "D0m7n7c",
  "repository": {
    "type": "git",
    "url": "https://github.com/D0m7n7c/joplin-plugin-quick-links-plus.git"
  },
  "homepage": "https://github.com/D0m7n7c/joplin-plugin-quick-links-plus",
  "bugs": {
    "url": "https://github.com/D0m7n7c/joplin-plugin-quick-links-plus/issues"
  }
}
